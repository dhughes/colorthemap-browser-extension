{
  "name": "colorthemap-browser-extension",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Cross-browser WebExtension that detects GPS file downloads and offers to import them into Color The Map.",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build && vite build --config vite.content.config.ts && node scripts/build-manifests.mjs",
    "package": "npm run build && node scripts/package.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/firefox-webext-browser": "^120.0.4",
    "@types/node": "^22.7.0",
    "@types/webextension-polyfill": "^0.12.1",
    "typescript": "^5.6.2",
    "vite": "^7.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  }
}
