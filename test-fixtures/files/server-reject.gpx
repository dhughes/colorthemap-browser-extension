<?xml version="1.0" encoding="UTF-8"?>
<!--
  A structurally valid GPX (root <gpx>) so the content sniff accepts it and the
  dialog appears. But it has no track (<trk>/<trkpt>) — only a waypoint — so
  Color The Map has nothing to import and rejects it server-side. This exercises
  the "passes detection, fails at CTM" path.
-->
<gpx version="1.1" creator="ctm-importer test fixtures"
     xmlns="http://www.topografix.com/GPX/1/1">
  <metadata>
    <name>No track here</name>
  </metadata>
  <wpt lat="35.990402" lon="-78.906296">
    <name>A lonely waypoint</name>
  </wpt>
</gpx>
