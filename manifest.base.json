{
  "manifest_version": 3,
  "name": "Color The Map Importer",
  "short_name": "CTM Importer",
  "version": "0.0.0",
  "description": "Detect GPS file downloads (GPX, FIT, TCX, KML, KMZ) and offer to import them into Color The Map.",
  "permissions": [],
  "host_permissions": [],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Color The Map Importer",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
