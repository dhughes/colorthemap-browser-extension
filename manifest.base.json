{
  "manifest_version": 3,
  "name": "Color The Map Importer",
  "short_name": "CTM Importer",
  "version": "0.0.0",
  "description": "Detect GPS file downloads (GPX, FIT, TCX, KML, KMZ) and offer to import them into Color The Map.",
  "key": "",
  "permissions": ["downloads", "identity", "alarms", "storage"],
  "host_permissions": [
    "https://dev.colorthemap.app/*",
    "https://colorthemap.app/*"
  ],
  "optional_host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
    {
      "resources": ["fonts/general-sans/*.woff2"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Color The Map Importer",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "background": {
    "service_worker": "background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.ts"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["detectors/detector-a-bridge.ts"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["detectors/detector-a-main.ts"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
