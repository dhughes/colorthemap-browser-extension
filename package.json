{
  "name": "colorthemap-browser-extension",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Cross-browser WebExtension that detects GPS file downloads and offers to import them into Color The Map.",
  "scripts": {
    "clean": "rm -rf dist artifacts",
    "generate:theme": "node scripts/generate-theme.ts",
    "generate:theme:check": "node scripts/generate-theme.ts --check",
    "check:theme": "node scripts/check-theme-generated.ts",
    "predev": "node scripts/generate-theme.ts",
    "prebuild": "node scripts/generate-theme.ts",
    "build": "npm run clean && npm run build:chrome && npm run build:edge && npm run build:firefox",
    "build:chrome": "TARGET_BROWSER=chrome vite build",
    "build:edge": "TARGET_BROWSER=edge vite build",
    "build:firefox": "TARGET_BROWSER=firefox vite build",
    "dev": "TARGET_BROWSER=chrome vite build --watch",
    "package": "npm run build && npm run package:chrome && npm run package:edge && npm run package:firefox",
    "package:chrome": "web-ext build -s dist/chrome -a artifacts -n chrome.zip -o -i \"**/*.map\" \"**/.gitkeep\"",
    "package:edge": "web-ext build -s dist/edge -a artifacts -n edge.zip -o -i \"**/*.map\" \"**/.gitkeep\"",
    "package:firefox": "web-ext build -s dist/firefox -a artifacts -n firefox.zip -o -i \"**/*.map\" \"**/.gitkeep\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --max-warnings 0 .",
    "format": "prettier --write \"src/**/*.{ts,html,css,json}\" \"scripts/**/*.ts\" \"*.{js,ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css,json}\" \"scripts/**/*.ts\" \"*.{js,ts,json}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.3.3",
    "@types/chrome": "^0.0.268",
    "@types/firefox-webext-browser": "^120.0.4",
    "@types/node": "^22.7.0",
    "@types/webextension-polyfill": "^0.12.1",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vite-plugin-web-extension": "^4.5.1",
    "vitest": "^4.1.0",
    "web-ext": "^10.4.0"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "fx-runner": "^1.5.0",
    "tmp": "^0.2.7",
    "uuid": "^11.1.1"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
